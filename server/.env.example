PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/divmeeting?retryWrites=true&w=majority
# or use MONGO_URI with the same connection string
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/divmeeting?retryWrites=true&w=majority
JWT_SECRET=replace_with_secure_secret
# Optional, but required for Google-like general AI answers.
# Gemini is used first when both keys are present.
GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# GEMINI_MODEL=gemini-2.5-flash
# Optional: set this to your tunnel/deployed frontend URL for mobile invites.
# PUBLIC_APP_URL=https://your-public-frontend-url
